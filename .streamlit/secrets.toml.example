# Copy to .streamlit/secrets.toml locally (gitignored), or paste into Streamlit Cloud > Settings > Secrets.

# Shared password — same value as oncura-programs + oncura-apps so the operator has one
# credential across the suite.
APP_PASSWORD = "change-me"

# GitHub Contents API token (Contents:write on this repo) for persisting the CIM crosswalk,
# the charge log, and the audit manifest. Without it, those live only in the Streamlit Cloud
# container's filesystem (session-only — lost on restart).
GITHUB_TOKEN = "ghp_xxx"

# Authorize.net API credentials. Use the SANDBOX values until production is approved.
# Sign in at https://sandbox.authorize.net to generate sandbox creds.
AUTHNET_API_LOGIN_ID = "sandbox-login-id"
AUTHNET_TRANSACTION_KEY = "sandbox-transaction-key"
# 'sandbox' = test environment, 'production' = live charges. ALWAYS start in sandbox.
AUTHNET_ENV = "sandbox"
